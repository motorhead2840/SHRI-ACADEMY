# SARA-EDU Platform - Repository Root Environment Configuration Example
# Copy this file to .env and configure the variables for local development or production.

# ------------------------------------------------------------------------------
# 1. API Server (Node.js) & Network Configuration
# ------------------------------------------------------------------------------
PORT=8080
NODE_ENV=development # Set to "production" in production deployments

# The frontend app url and the webhook callback base url
APP_URL=http://localhost:3000
WEBHOOK_BASE_URL=http://localhost:8080

# ------------------------------------------------------------------------------
# 2. Database Connection
# ------------------------------------------------------------------------------
# PostgreSQL database connection string
DATABASE_URL=******localhost:5432/sriplatform

# ------------------------------------------------------------------------------
# 3. Stripe Integration (Required for subscription/payments)
# ------------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ------------------------------------------------------------------------------
# 4. AWS Services & SecOps Configuration
# ------------------------------------------------------------------------------
AWS_REGION=us-east-1
# AWS credentials (if not running on an IAM-role-enabled platform like ECS/EC2)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# SageMaker pipeline and SecOps S3 Bucket
RAGETHESAGE_PIPELINE_ARN=arn:aws:sagemaker:us-east-1:123456789012:pipeline/ragethesage
SECOPS_S3_BUCKET=sri-production-secops

# ------------------------------------------------------------------------------
# 5. Smart Contract Configuration (SARA Token)
# ------------------------------------------------------------------------------
SARA_CONTRACT_ADDRESS=0x...
VITE_SARA_CONTRACT_ADDRESS=0x...

# ------------------------------------------------------------------------------
# 6. Python Sidecar Configuration (Optional for local dev)
# ------------------------------------------------------------------------------
PYTHON_SIDECAR_ENABLED=false
# PYTHON_BIN=python3
# PY_API_DIR=./shri-academy-api
