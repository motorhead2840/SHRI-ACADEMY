# SHRI-ACADEMY-API Environment Variables Configuration Example
# Copy this file to .env and configure the variables.

# FastAPI App Port
PORT=8000

# AI Mentor Evaluation Mode (Set to "true" to enable SageMaker parallel eval mode)
MENTOR_EVAL_MODE=false

# NVIDIA API Key (for LLM / Nemotron support)
NVIDIA_API_KEY=nvapi-key-here

# Confluent Cloud (Kafka) Configuration
KAFKA_BOOTSTRAP_SERVERS=your-confluent-bootstrap-servers:9092
KAFKA_API_KEY=your-confluent-api-key
KAFKA_API_SECRET=your-confluent-api-secret

# AWS SageMaker Integration Configuration
SAGEMAKER_ENDPOINT_NAME=shri-mentor-v1
AWS_REGION=us-east-1

# AWS Credentials (if not running with an IAM execution role)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_SESSION_TOKEN=your-aws-session-token-optional

# SageMaker pipeline and S3 Buckets
SAGEMAKER_ROLE_ARN=arn:aws:iam::123456789012:role/service-role/AmazonSageMaker-ExecutionRole
SAGEMAKER_S3_BUCKET=your-sagemaker-s3-bucket
MENTOR_API_SECRET=your-mentor-api-secret-key
