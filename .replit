modules = ["nodejs-24", "python-base-3.13"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
AWS_BLOCKCHAIN_NODE_URL = ""
AWS_REGION = "us-east-1"
ETHEREUM_NETWORK = "sepolia"
SARA_CONTRACT_ADDRESS = ""
VITE_API_URL = ""
VITE_SARA_CONTRACT_ADDRESS = ""
